#!/usr/bin/env bash
# Flutter-style wrapper stub - delegates to wrapper jar if available
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
WRAPPER_JAR="$HOME/.gradle/wrapper/gradle-wrapper.jar"
if [ -f "$WRAPPER_JAR" ]; then
  java -jar "$WRAPPER_JAR" "$@"
else
  echo "Gradle wrapper jar not found at $WRAPPER_JAR"
  exit 1
fi
